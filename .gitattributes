# Normalize line endings to LF for all text files.
# Prevents CRLF/LF merge conflicts when cherry-picking from upstream.

* text=auto eol=lf

# Explicit declarations for source files
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.py text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.plist text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.jar binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
