<?xml version="1.0" encoding="utf-8"?>
<!--
    This app is a client for a user-controlled OpenCode server. Users connect
    to their own servers via HTTPS (public domain), HTTP reverse proxy, LAN IP,
    localhost, SSH tunnel, etc. Restricting cleartext HTTP would break LAN and
    localhost connections that are the primary use case. Permit cleartext for
    all destinations — the user decides what to trust.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
