<?xml version="1.0" encoding="utf-8"?>
<!--
   Exclude shared_prefs from cloud backup and device transfer.
   Credentials in EncryptedSharedPreferences must not leave the device.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>