<?xml version="1.0" encoding="utf-8"?>
<!--
   Exclude shared_prefs from backup - contains EncryptedSharedPreferences
   (server URL, credentials). Other app data may still be backed up.
   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <exclude domain="sharedpref" path="."/>
</full-backup-content>